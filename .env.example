# ─── Required ────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-here

# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Optional (defaults shown) ──────────────────────
JWT_EXPIRY=7d
AI_PROVIDER=gemini
# Comma-separated list. Include marketing site, dashboard, and any local dev origins.
CORS_ORIGIN=https://bhashajs.com,https://app.bhashajs.com

# ─── Email (for invite delivery) ──────────────────────────────
# Recommended: Resend (3000/mo free) — sign up at https://resend.com
# Once verified, your DNS is set, the SMTP creds look like:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_your_resend_api_key
# Any SMTP provider works (Postmark, SendGrid, Gmail, AWS SES, etc.).
# If left blank, invite emails are logged to the server console instead of sent.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BhashaJS <noreply@bhashajs.com>

# Public URL where the dashboard lives — used to build invite links in emails.
APP_URL=https://app.bhashajs.com

# Generate a strong password for production!
MONGO_ROOT_PASSWORD=changeme
