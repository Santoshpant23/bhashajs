# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
# Local dev: mongodb://localhost:27017/bhashajs
# Docker:    mongodb://root:changeme@localhost:27017/bhashajs?authSource=admin
MONGO_CONNECTION_URL=mongodb://localhost:27017/bhashajs

# ─── Auth ─────────────────────────────────────────────
# REQUIRED: generate a strong random secret
# e.g.: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-here
JWT_EXPIRY=7d

# ─── CORS ─────────────────────────────────────────────
# Dev: * (allow all)
# Prod: https://yourdomain.com
CORS_ORIGIN=*

# ─── AI Provider ──────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Docker only ──────────────────────────────────────
MONGO_ROOT_PASSWORD=changeme
