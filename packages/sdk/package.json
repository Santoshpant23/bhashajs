{
  "name": "bhasha-js",
  "version": "0.2.0",
  "description": "React i18n built for South Asian languages — Hindi, Bengali, Urdu, Tamil, Telugu, Marathi, Punjabi, Gujarati, Kannada, Malayalam, Nepali, Sinhala — with auto RTL, lakh/crore numbers, native digits, region-aware currency, and CLDR plurals.",
  "author": "Santosh",
  "license": "MIT",
  "homepage": "https://bhashajs.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santoshpant23/bhashajs.git"
  },
  "bugs": {
    "url": "https://github.com/santoshpant23/bhashajs/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "react",
    "react-i18n",
    "translation",
    "translations",
    "multilingual",
    "locale",
    "intl",
    "hindi",
    "hindi-i18n",
    "bengali",
    "bangla",
    "urdu",
    "tamil",
    "telugu",
    "marathi",
    "gujarati",
    "kannada",
    "malayalam",
    "nepali",
    "sinhala",
    "punjabi",
    "gurmukhi",
    "shahmukhi",
    "devanagari",
    "south-asian",
    "south-asia",
    "indic",
    "india",
    "bangladesh",
    "pakistan",
    "nepal",
    "sri-lanka",
    "rtl",
    "right-to-left",
    "lakh",
    "crore",
    "lakh-crore",
    "indian-numbering",
    "native-digits",
    "pluralization",
    "cldr",
    "icu",
    "currency",
    "rupee",
    "taka",
    "i18next-alternative",
    "react-intl-alternative"
  ],
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "~5.6.2",
    "vitest": "^4.1.0"
  }
}
